# ─────────────────────────────────────────────────────────────
# CollegeReadyJobs — Environment Variables
# Copy this file to .env.local and fill in your keys.
# Add ALL of these to Vercel → Settings → Environment Variables
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude AI) — console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Adzuna Jobs API — developer.adzuna.com
ADZUNA_APP_ID=7945d87d
ADZUNA_APP_KEY=your_new_rotated_key_here

# Supabase — supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App URL (your Vercel URL after deploy)
NEXT_PUBLIC_APP_URL=https://collegerreadyjobs.vercel.app
